{
  "name": "@packages/supabase",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./nextjs/server": "./src/nextjs/server.ts",
    "./nextjs/client": "./src/nextjs/client.ts",
    "./nextjs/proxy": "./src/nextjs/proxy.ts",
    "./nextjs/public-config": "./src/nextjs/public-config.ts",
    "./nextjs/private-config": "./src/nextjs/private-config.ts"
  },
  "scripts": {
    "dev": "SUPABASE_PROJECT=ai-driven-starter_$(basename \"$(git rev-parse --show-toplevel)\") supabase start",
    "stop": "SUPABASE_PROJECT=ai-driven-starter_$(basename \"$(git rev-parse --show-toplevel)\") supabase stop",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "next": ">=16"
  },
  "dependencies": {
    "@supabase/ssr": "catalog:",
    "@supabase/supabase-js": "catalog:",
    "valibot": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "next": "catalog:",
    "typescript": "catalog:"
  }
}
