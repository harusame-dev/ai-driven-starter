{
  "$schema": "https://turborepo.com/schema.json",
  "globalEnv": ["WORKTREE_NAME", "SUPABASE_DB_PORT", "SUPABASE_API_PORT"],
  "tasks": {
    "dev:portless:web": {
      "cache": false,
      "persistent": true
    },
    "dev:portless": {
      "dependsOn": ["^dev"],
      "cache": false,
      "persistent": true
    },
    "dev": {
      "dependsOn": ["^dev"],
      "cache": false,
      "persistent": true
    },
    "@packages/supabase#dev": {
      "cache": false,
      "persistent": false
    }
  }
}
